
# APPLICATION

APP_NAME="E-Commerce Management System"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://ems.bunli-it.site

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12



# LOGGING

LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error



# DATABASE - RAILWAY MYSQL

DB_CONNECTION=mysql
DB_HOST=${{MySQL.MYSQLHOST}}
DB_PORT=${{MySQL.MYSQLPORT}}
DB_DATABASE=${{MySQL.MYSQLDATABASE}}
DB_USERNAME=${{MySQL.MYSQLUSER}}
DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}



# SESSION

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.bunli-it.site
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax



# CACHE, QUEUE AND BROADCAST

CACHE_STORE=database
CACHE_PREFIX=ems_cache

QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log



# REDIS
# Use only when Redis is added to Railway

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1



# FILE STORAGE

FILESYSTEM_DISK=public



# EMAIL - SENDGRID SMTP

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=YOUR_NEW_SENDGRID_API_KEY
MAIL_FROM_ADDRESS="no-reply@bunli-it.site"
MAIL_FROM_NAME="${APP_NAME}"

SENDGRID_API_KEY=YOUR_NEW_SENDGRID_API_KEY



# BAKONG KHQR

BAKONG_TOKEN=
BAKONG_ACCOUNT_ID=
BAKONG_MERCHANT_NAME="BUNLY SEM"
BAKONG_MERCHANT_CITY="Phnom Penh"



# TELEGRAM ORDER NOTIFICATION

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=



# GOOGLE OAUTH

GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_NEW_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://ems.bunli-it.site/auth/google-callback



# AMAZON S3
# Required only when FILESYSTEM_DISK=s3

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false



# API DOCUMENTATION

L5_SWAGGER_GENERATE_ALWAYS=false
L5_SWAGGER_CONST_HOST=https://ems.bunli-it.site



# VITE

VITE_APP_NAME="${APP_NAME}"
